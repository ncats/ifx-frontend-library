{
  "name": "rdas-express",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/rdas-express/src",
  "projectType": "application",
  "type": "module",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "options": {
        "generatePackageJson": true,
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/rdas-express",
        "main": "apps/rdas-express/src/main.ts",
        "tsConfig": "apps/rdas-express/tsconfig.app.json",
        "assets": ["apps/rdas-express/src/assets"],
        "webpackConfig": "apps/rdas-express/webpack.config.js"
      },
      "configurations": {
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false
        },
        "testenv": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false
        },
        "local": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "rdas-express:build"
      },
      "configurations": {
        "production": {
          "buildTarget": "rdas-express:build:production"
        },
        "development": {
          "buildTarget": "rdas-express:build:development"
        },
        "local": {
          "buildTarget": "rdas-express:build:local"
        }
      }
    },
    "lint": {
      "inputs": [
        "default",
        "{workspaceRoot}/.eslintignore",
        "{workspaceRoot}/eslint.config.mjs",
        {
          "externalDependencies": ["eslint"]
        }
      ]
    }
  }
}
